# ==========================================
# 1. Python & Jupyter 缓存
# ==========================================
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/

# ==========================================
# 2. 大型数据库与输出结果 (核心生信规则)
# ==========================================
# 忽略解压后的完整 Swiss-Prot 参考库
data/uniprot_sprot.fasta
# 忽略可能下载的原始压缩包
data/uniprot_sprot.fasta.gz
# 忽略所有的索引缓存文件
data/*.index
# 忽略比对输出结果 (包含根目录和 data 目录下的 tsv)
*.tsv
data/*.tsv

# ==========================================
# 3. 本地运行输出与日志
# ==========================================
output/
*.log

# ==========================================
# 4. 系统垃圾文件
# ==========================================
.DS_Store
Thumbs.db
